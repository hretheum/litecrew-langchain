# Production environment configuration
# Copy this file and fill with real values

# Environment
ENVIRONMENT=production

# API Keys (required - at least one)
OPENAI_API_KEY=your-production-openai-key
# ANTHROPIC_API_KEY=your-production-anthropic-key
# GROQ_API_KEY=your-production-groq-key

# Database (using Docker services)
DATABASE_URL=postgresql://litecrew:litecrew@postgres:5432/litecrew
REDIS_URL=redis://redis:6379/0

# Security (MUST CHANGE!)
SECRET_KEY=generate-strong-secret-key-for-production-use-openssl-rand-hex-32
JWT_SECRET=generate-strong-jwt-secret-for-production-use-openssl-rand-hex-32

# Server
HOST=0.0.0.0
PORT=8000

# Optional monitoring
# SENTRY_DSN=your-sentry-dsn
# DISCORD_WEBHOOK=your-discord-webhook