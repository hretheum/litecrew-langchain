# Security Configuration Example
# Copy to .env and fill with your values

# API Key Authentication
# Generate keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LITECREW_API_KEYS=your-api-key-1,your-api-key-2

# Google OAuth Configuration
# Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Access Control (optional)
# Leave empty to allow all Google accounts
ALLOWED_EMAIL_DOMAINS=yourdomain.com
ALLOWED_EMAILS=admin@gmail.com,user@example.com

# JWT & Session Secrets
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=generate-a-secure-random-string-here
SESSION_SECRET=generate-another-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Dashboard Security
REQUIRE_DASHBOARD_AUTH=true

# CORS Configuration
# Production: set specific origins
# Development: leave empty for * (all origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Host Header Validation (production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_AUTH_MULTIPLIER=10

# Environment
ENVIRONMENT=development