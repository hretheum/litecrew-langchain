# Test environment for security features

# API Key Authentication
LITECREW_API_KEYS=test-key-123,dev-key-456

# Dashboard Auth (set to false for testing without Google OAuth)
REQUIRE_DASHBOARD_AUTH=false

# Environment
ENVIRONMENT=development

# CORS (allow localhost for testing)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Session secret for testing
SESSION_SECRET=test-session-secret-for-development-only

# Rate limiting (relaxed for testing)
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20