# LiteCrewAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env file!

# API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GROQ_API_KEY=your-groq-api-key-here
OLLAMA_HOST=http://localhost:11434

# Database Configuration
DATABASE_URL=postgresql://litecrewai:your-password@localhost:5432/litecrewai
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=generate-a-long-random-string-here
JWT_SECRET=generate-another-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Metrics Authentication (REQUIRED - no defaults!)
METRICS_USERNAME=choose-secure-username
METRICS_PASSWORD=use-very-strong-password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,https://app.litecrewai.com

# Monitoring (Optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Infrastructure
DROPLET_IP=46.101.181.183
SSH_KEY_PATH=~/.ssh/id_rag
SSH_USER=root

# Feature Flags
ENABLE_TELEMETRY=false
ENABLE_ANALYTICS=false
DEBUG=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Resource Limits
MAX_AGENTS_PER_USER=50
MAX_CONCURRENT_TASKS=100
MAX_MEMORY_PER_AGENT_MB=10
TASK_TIMEOUT_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/litecrewai/app.log

# Alert Configuration
# Option 1: Telegram alerts (recommended)
ALERT_WEBHOOK_URL=telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# To get bot token:
# 1. Message @BotFather on Telegram
# 2. Create new bot with /newbot
# 3. Copy the token
# To get chat ID:
# 1. Message your bot
# 2. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Look for 'chat':{'id':YOUR_CHAT_ID}

# Option 2: Discord/Slack webhook
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...